pub let length[T]: fn(List[T]) -> i32 = src.types.length
pub let list_map[A, B]: fn(List[A], fn(A) -> B) -> List[B] = src.types.list_map
pub let fold[A, B]: fn(List[A], B, fn(B, A) -> B) -> B = src.types.fold


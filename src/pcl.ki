/// Parser Combinator Library (PCL) - Main Module
///
/// A comprehensive parser combinator library for Kira that demonstrates:
/// - Algebraic Data Types (sum types, product types)
/// - Generics and type parameters
/// - Higher-order functions
/// - Purity and effect separation
/// - Pattern matching
/// - Rich error handling
///
/// ## Quick Start
///
/// ```kira
/// import src.pcl
///
/// // Parse a simple identifier
/// let id_parser: Parser[string] = identifier()
/// let result: Result[string, ParseError] = parse[string](id_parser, "foo")
///
/// // Parse comma-separated integers
/// let nums_parser: Parser[List[i64]] = comma_sep[i64](integer())
/// let result: Result[List[i64], ParseError] = parse[List[i64]](nums_parser, "1, 2, 3")
/// ```
///
/// ## Module Organization
///
/// - `types.ki`: Core types (Position, Input, ParseResult, ParseError)
/// - `primitives.ki`: Basic parsers (char_p, string_p, digit, letter, etc.)
/// - `combinators.ki`: Parser combinators (and_then, or_else, many, etc.)
/// - `lexer.ki`: Token-level parsing (identifier, integer, string_literal)
/// - `expr.ki`: Expression parsing (chainl1, build_expr_parser)
/// - `io.ki`: File parsing and error formatting

module pcl

// =============================================================================
// Re-export Core Types
// =============================================================================

// From types.ki
pub type Position = src.types.Position
pub type Input = src.types.Input
pub type Expected = src.types.Expected
pub type ParseError = src.types.ParseError
pub type ParseResult[T] = src.types.ParseResult[T]
pub type Parser[T] = src.types.Parser[T]

pub let position_new: fn(i64, i32, i32) -> Position = src.types.position_new
pub let input_new: fn(string) -> Input = src.types.input_new
pub let error_at: fn(Position, Expected, Option[char]) -> ParseError = src.types.error_at
pub let merge_errors: fn(ParseError, ParseError) -> ParseError = src.types.merge_errors
pub let is_success[T]: fn(ParseResult[T]) -> bool = src.types.is_success
pub let is_failure[T]: fn(ParseResult[T]) -> bool = src.types.is_failure

// String utilities
pub let substring: fn(string, i64) -> string = src.types.substring
pub let string_head: fn(string) -> Option[char] = src.types.string_head
pub let string_is_empty: fn(string) -> bool = src.types.string_is_empty
pub let starts_with: fn(string, string) -> bool = src.types.starts_with
pub let string_contains_char: fn(string, char) -> bool = src.types.string_contains_char
pub let char_to_string: fn(char) -> string = src.types.char_to_string
pub let chars_to_string: fn(List[char]) -> string = src.types.chars_to_string
pub let string_to_i64: fn(string) -> i64 = src.types.string_to_i64
pub let i64_to_f64: fn(i64) -> f64 = src.types.i64_to_f64

// Position utilities
pub let advance_position: fn(Position, char) -> Position = src.types.advance_position
pub let advance_position_by_string: fn(Position, string) -> Position = src.types.advance_position_by_string

// List utilities
pub let reverse[T]: fn(List[T]) -> List[T] = src.types.reverse

// Repetition
pub let many[T]: fn(Parser[T]) -> Parser[List[T]] = src.combinators.many
pub let many1[T]: fn(Parser[T]) -> Parser[List[T]] = src.combinators.many1
pub let count[T]: fn(i32, Parser[T]) -> Parser[List[T]] = src.combinators.count
pub let sep_by[T, S]: fn(Parser[T], Parser[S]) -> Parser[List[T]] = src.combinators.sep_by
pub let sep_by1[T, S]: fn(Parser[T], Parser[S]) -> Parser[List[T]] = src.combinators.sep_by1
pub let end_by[T, S]: fn(Parser[T], Parser[S]) -> Parser[List[T]] = src.combinators.end_by

// Lookahead
pub let lookahead[T]: fn(Parser[T]) -> Parser[T] = src.combinators.lookahead
pub let not_followed_by[T]: fn(Parser[T]) -> Parser[void] = src.combinators.not_followed_by
pub let try_p[T]: fn(Parser[T]) -> Parser[T] = src.combinators.try_p

// Error enhancement
pub let label[T]: fn(Parser[T], string) -> Parser[T] = src.combinators.label
pub let context[T]: fn(Parser[T], string) -> Parser[T] = src.combinators.context

// Recursion
pub type LazyParser[T] = src.combinators.LazyParser[T]
pub let lazy[T]: fn(fn() -> Parser[T]) -> Parser[T] = src.combinators.lazy
pub let fix[T]: fn(fn(Parser[T]) -> Parser[T]) -> Parser[T] = src.combinators.fix


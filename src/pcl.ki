pub let optional[T]: fn(Parser[T]) -> Parser[Option[T]] = src.combinators.optional

// Transformation
pub let map[A, B]: fn(Parser[A], fn(A) -> B) -> Parser[B] = src.combinators.map
pub let map2[A, B, C]: fn(Parser[A], Parser[B], fn(A, B) -> C) -> Parser[C] = src.combinators.map2
pub let map3[A, B, C, D]: fn(Parser[A], Parser[B], Parser[C], fn(A, B, C) -> D) -> Parser[D] = src.combinators.map3

// Tests for the JSON parser example

import src.types
import src.primitives
import src.combinators
import src.lexer
import examples.json

// =============================================================================
// Null Tests
// =============================================================================

fn test_parse_null() -> void {
    let result: Result[Value, ParseError] = parse_json("null")
    match result {
        Ok(v) => {
            match v {
                VVoid => { return }
                _ => { assert(false, "expected VVoid for null") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_null_with_whitespace() -> void {
    let result: Result[Value, ParseError] = parse_json("  null  ")
    match result {
        Ok(v) => {
            match v {
                VVoid => { return }
                _ => { assert(false, "expected VVoid for null") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

// =============================================================================
// Boolean Tests
// =============================================================================

fn test_parse_true() -> void {
    let result: Result[Value, ParseError] = parse_json("true")
    match result {
        Ok(v) => {
            match v {
                VBool(b) => { assert(b, "expected true") }
                _ => { assert(false, "expected VBool") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_false() -> void {
    let result: Result[Value, ParseError] = parse_json("false")
    match result {
        Ok(v) => {
            match v {
                VBool(b) => { assert(not b, "expected false") }
                _ => { assert(false, "expected VBool") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

// =============================================================================
// Number Tests
// =============================================================================

fn test_parse_integer() -> void {
    let result: Result[Value, ParseError] = parse_json("42")
    match result {
        Ok(v) => {
            match v {
                VFloat(n) => { assert(n > 41.0 and n < 43.0, "expected ~42") }
                VInt(n) => { assert(n == 42i64, "expected 42") }
                _ => { assert(false, "expected VFloat or VInt") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_float() -> void {
    let result: Result[Value, ParseError] = parse_json("3.14")
    match result {
        Ok(v) => {
            match v {
                VFloat(n) => { assert(n > 3.13 and n < 3.15, "expected ~3.14") }
                _ => { assert(false, "expected VFloat") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_zero() -> void {
    let result: Result[Value, ParseError] = parse_json("0")
    match result {
        Ok(v) => {
            match v {
                VFloat(n) => { assert(n > -0.1 and n < 0.1, "expected ~0") }
                VInt(n) => { assert(n == 0i64, "expected 0") }
                _ => { assert(false, "expected VFloat or VInt") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

// =============================================================================
// String Tests
// =============================================================================

fn test_parse_string_simple() -> void {
    let result: Result[Value, ParseError] = parse_json("\"hello\"")
    match result {
        Ok(v) => {
            match v {
                VString(s) => { assert(s == "hello", "expected 'hello'") }
                _ => { assert(false, "expected VString") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_string_escaped() -> void {
    let result: Result[Value, ParseError] = parse_json("\"hello\\nworld\"")
    match result {
        Ok(v) => {
            match v {
                VString(s) => { assert(s == "hello\nworld", "expected escaped newline") }
                _ => { assert(false, "expected VString") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_string_empty() -> void {
    let result: Result[Value, ParseError] = parse_json("\"\"")
    match result {
        Ok(v) => {
            match v {
                VString(s) => { assert(s == "", "expected empty string") }
                _ => { assert(false, "expected VString") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

// =============================================================================
// Array Tests
// =============================================================================

fn test_parse_empty_array() -> void {
    let result: Result[Value, ParseError] = parse_json("[]")
    match result {
        Ok(v) => {
            match v {
                VList(items) => { assert(std.list.length(items) == 0, "expected empty array") }
                _ => { assert(false, "expected VList") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_array_one_element() -> void {
    let result: Result[Value, ParseError] = parse_json("[1]")
    match result {
        Ok(v) => {
            match v {
                VList(items) => { assert(std.list.length(items) == 1, "expected one element") }
                _ => { assert(false, "expected VList") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_array_multiple() -> void {
    let result: Result[Value, ParseError] = parse_json("[1, 2, 3]")
    match result {
        Ok(v) => {
            match v {
                VList(items) => { assert(std.list.length(items) == 3, "expected three elements") }
                _ => { assert(false, "expected VList") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_nested_array() -> void {
    let result: Result[Value, ParseError] = parse_json("[[1, 2], [3, 4]]")
    match result {
        Ok(v) => {
            match v {
                VList(items) => { assert(std.list.length(items) == 2, "expected two elements") }
                _ => { assert(false, "expected VList") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_mixed_array() -> void {
    let result: Result[Value, ParseError] = parse_json("[1, \"hello\", true, null]")
    match result {
        Ok(v) => {
            match v {
                VList(items) => { assert(std.list.length(items) == 4, "expected four elements") }
                _ => { assert(false, "expected VList") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

// =============================================================================
// Object Tests
// =============================================================================

fn test_parse_empty_object() -> void {
    let result: Result[Value, ParseError] = parse_json("{}")
    match result {
        Ok(v) => {
            match v {
                VList(items) => { assert(std.list.length(items) == 0, "expected empty object") }
                _ => { assert(false, "expected VList") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_object_one_pair() -> void {
    let result: Result[Value, ParseError] = parse_json("{\"name\": \"Alice\"}")
    match result {
        Ok(v) => {
            match v {
                VList(items) => { assert(std.list.length(items) == 1, "expected one pair") }
                _ => { assert(false, "expected VList") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_object_multiple() -> void {
    let result: Result[Value, ParseError] = parse_json("{\"name\": \"Alice\", \"age\": 30}")
    match result {
        Ok(v) => {
            match v {
                VList(items) => { assert(std.list.length(items) == 2, "expected two pairs") }
                _ => { assert(false, "expected VList") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_nested_object() -> void {
    let result: Result[Value, ParseError] = parse_json("{\"person\": {\"name\": \"Alice\"}}")
    match result {
        Ok(v) => {
            match v {
                VList(_) => { return }
                _ => { assert(false, "expected VList") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

// =============================================================================
// Complex JSON Tests
// =============================================================================

fn test_parse_complex_json() -> void {
    let input: string = "{\"users\": [{\"name\": \"Alice\", \"active\": true}, {\"name\": \"Bob\", \"active\": false}]}"
    let result: Result[Value, ParseError] = parse_json(input)
    match result {
        Ok(v) => {
            match v {
                VList(_) => { return }
                _ => { assert(false, "expected VList") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

fn test_parse_whitespace_handling() -> void {
    let input: string = "  {  \"key\"  :  \"value\"  }  "
    let result: Result[Value, ParseError] = parse_json(input)
    match result {
        Ok(v) => {
            match v {
                VList(_) => { return }
                _ => { assert(false, "expected VList") }
            }
        }
        Err(_) => { assert(false, "should succeed") }
    }
}

// =============================================================================
// Error Tests
// =============================================================================

fn test_parse_error_unclosed_array() -> void {
    let result: Result[Value, ParseError] = parse_json("[1, 2, 3")
    match result {
        Ok(_) => { assert(false, "should fail on unclosed array") }
        Err(_) => { return }
    }
}

fn test_parse_error_unclosed_object() -> void {
    let result: Result[Value, ParseError] = parse_json("{\"key\": \"value\"")
    match result {
        Ok(_) => { assert(false, "should fail on unclosed object") }
        Err(_) => { return }
    }
}

fn test_parse_error_invalid_value() -> void {
    let result: Result[Value, ParseError] = parse_json("undefined")
    match result {
        Ok(_) => { assert(false, "should fail on invalid value") }
        Err(_) => { return }
    }
}

// =============================================================================
// Accessor Tests
// =============================================================================

fn test_json_get() -> void {
    let result: Result[Value, ParseError] = parse_json("{\"name\": \"Alice\"}")
    match result {
        Ok(obj) => {
            match json_get(obj, "name") {
                Some(v) => {
                    match v {
                        VString(s) => { assert(s == "Alice", "expected 'Alice'") }
                        _ => { assert(false, "expected VString") }
                    }
                }
                None => { assert(false, "key should exist") }
            }
        }
        Err(_) => { assert(false, "should parse") }
    }
    return
}

fn test_json_get_missing() -> void {
    let result: Result[Value, ParseError] = parse_json("{\"name\": \"Alice\"}")
    match result {
        Ok(obj) => {
            match json_get(obj, "age") {
                Some(_) => { assert(false, "key should not exist") }
                None => { return }
            }
        }
        Err(_) => { assert(false, "should parse") }
    }
}

fn test_json_index() -> void {
    let result: Result[Value, ParseError] = parse_json("[10, 20, 30]")
    match result {
        Ok(arr) => {
            match json_index(arr, 1) {
                Some(v) => {
                    match v {
                        VFloat(n) => { assert(n > 19.0 and n < 21.0, "expected ~20") }
                        VInt(n) => { assert(n == 20i64, "expected 20") }
                        _ => { assert(false, "expected number") }
                    }
                }
                None => { assert(false, "index should exist") }
            }
        }
        Err(_) => { assert(false, "should parse") }
    }
    return
}

// =============================================================================
// Round-trip Tests
// =============================================================================

fn test_json_to_string_null() -> void {
    let s: string = json_to_string(VVoid)
    assert(s == "null", "expected 'null'")
    return
}

fn test_json_to_string_bool() -> void {
    let s1: string = json_to_string(VBool(true))
    assert(s1 == "true", "expected 'true'")
    let s2: string = json_to_string(VBool(false))
    assert(s2 == "false", "expected 'false'")
    return
}

let test_map_transforms_value: fn() -> void = fn() -> void {
    let parser: Parser[i32] = map[char, i32](digit(), fn(c: char) -> i32 {
        return std.char.to_digit(c)
    })
    let result: ParseResult[i32] = run[i32](parser, "5abc")
    match result {
        Success { value: n, remaining: _ } => {
            assert(n == 5, "should parse 5")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_map2_combines_two: fn() -> void = fn() -> void {
    let parser: Parser[string] = map2[char, char, string](
        char_p('a'),
        char_p('b'),
        fn(c1: char, c2: char) -> string {
            return chars_to_string(Cons(c1, Cons(c2, Nil)))
        }
    )
    let result: ParseResult[string] = run[string](parser, "abc")
    match result {
        Success { value: s, remaining: _ } => {
            assert(s == "ab", "should combine to 'ab'")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_map3_combines_three: fn() -> void = fn() -> void {
    let parser: Parser[string] = map3[char, char, char, string](
        char_p('a'),
        char_p('b'),
        char_p('c'),
        fn(c1: char, c2: char, c3: char) -> string {
            return chars_to_string(Cons(c1, Cons(c2, Cons(c3, Nil))))
        }
    )
    let result: ParseResult[string] = run[string](parser, "abcd")
    match result {
        Success { value: s, remaining: _ } => {
            assert(s == "abc", "should combine to 'abc'")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_replace_replaces_value: fn() -> void = fn() -> void {
    let parser: Parser[i32] = replace[char, i32](char_p('x'), 42)
    let result: ParseResult[i32] = run[i32](parser, "xyz")
    match result {
        Success { value: n, remaining: _ } => {
            assert(n == 42, "should replace with 42")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}


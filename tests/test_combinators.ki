// Tests for the combinators module

import src.types
import src.primitives
import src.combinators

// =============================================================================
// Sequencing Tests
// =============================================================================

test "and then success" {
    let parser: fn(Input) -> ParseResult = and_then(
        char_p('a'),
        fn(a_val: Value) -> fn(Input) -> ParseResult {
            return map_p(char_p('b'), fn(b_val: Value) -> Value {
                let a_c: char = unwrap_char(a_val)
                let b_c: char = unwrap_char(b_val)
                return VString(to_string(a_c) + to_string(b_c))
            })
        }
    )
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, _) => {
            assert(unwrap_string(v) == "ab", "should parse 'ab'")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "and then first fails" {
    let parser: fn(Input) -> ParseResult = and_then(
        char_p('x'),
        fn(_: Value) -> fn(Input) -> ParseResult { return char_p('y') }
    )
    let result: ParseResult = run(parser, "abc")
    assert(is_failure(result), "should fail when first parser fails")
}

test "and then second fails" {
    let parser: fn(Input) -> ParseResult = and_then(
        char_p('a'),
        fn(_: Value) -> fn(Input) -> ParseResult { return char_p('x') }
    )
    let result: ParseResult = run(parser, "abc")
    assert(is_failure(result), "should fail when second parser fails")
}

test "seq left keeps left" {
    let parser: fn(Input) -> ParseResult = seq_left(char_p('a'), char_p('b'))
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, rest) => {
            assert(unwrap_char(v) == 'a', "should return 'a'")
            assert(rest.pos.offset == 2, "should consume both chars")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "seq right keeps right" {
    let parser: fn(Input) -> ParseResult = seq_right(char_p('a'), char_p('b'))
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, rest) => {
            assert(unwrap_char(v) == 'b', "should return 'b'")
            assert(rest.pos.offset == 2, "should consume both chars")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "seq pair keeps both" {
    let parser: fn(Input) -> ParseResult = seq_pair(char_p('a'), char_p('b'))
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, _) => {
            match v {
                VPair(a, b) => {
                    assert(unwrap_char(a) == 'a', "first should be 'a'")
                    assert(unwrap_char(b) == 'b', "second should be 'b'")
                }
                _ => { assert(false, "should be VPair") }
            }
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "between extracts middle" {
    let parser: fn(Input) -> ParseResult = between(
        char_p('('),
        char_p('x'),
        char_p(')')
    )
    let result: ParseResult = run(parser, "(x)")
    match result {
        Success(v, rest) => {
            assert(unwrap_char(v) == 'x', "should extract 'x'")
            assert(rest.pos.offset == 3, "should consume all three chars")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

// =============================================================================
// Alternation Tests
// =============================================================================

test "or else first succeeds" {
    let parser: fn(Input) -> ParseResult = or_else(char_p('a'), char_p('b'))
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, _) => {
            assert(unwrap_char(v) == 'a', "should return 'a'")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "or else second succeeds" {
    let parser: fn(Input) -> ParseResult = or_else(char_p('x'), char_p('a'))
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, _) => {
            assert(unwrap_char(v) == 'a', "should return 'a' from second parser")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "or else both fail merges errors" {
    let parser: fn(Input) -> ParseResult = or_else(char_p('x'), char_p('y'))
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(_, _) => {
            assert(false, "should fail")
        }
        Failure(e) => {
            assert(std.list.length(e.expected) == 2, "should merge expected lists")
        }
    }
}

test "choice empty list" {
    let parsers: List[fn(Input) -> ParseResult] = Nil
    let parser: fn(Input) -> ParseResult = choice(parsers)
    let result: ParseResult = run(parser, "abc")
    assert(is_failure(result), "choice of empty list should fail")
}

test "choice first match" {
    let parsers: List[fn(Input) -> ParseResult] = Cons(char_p('a'), Cons(char_p('b'), Cons(char_p('c'), Nil)))
    let parser: fn(Input) -> ParseResult = choice(parsers)
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, _) => {
            assert(unwrap_char(v) == 'a', "should match first")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "choice later match" {
    let parsers: List[fn(Input) -> ParseResult] = Cons(char_p('x'), Cons(char_p('y'), Cons(char_p('a'), Nil)))
    let parser: fn(Input) -> ParseResult = choice(parsers)
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, _) => {
            assert(unwrap_char(v) == 'a', "should match third")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "optional present" {
    let parser: fn(Input) -> ParseResult = optional(char_p('a'))
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, _) => {
            match v {
                VChar(c) => { assert(c == 'a', "should be 'a'") }
                _ => { assert(false, "should be VChar") }
            }
        }
        Failure(_) => {
            assert(false, "optional should never fail")
        }
    }
}

test "optional absent" {
    let parser: fn(Input) -> ParseResult = optional(char_p('x'))
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, rest) => {
            match v {
                VVoid => { assert(rest.pos.offset == 0, "should not consume input") }
                _ => { assert(false, "should be VVoid") }
            }
        }
        Failure(_) => {
            assert(false, "optional should never fail")
        }
    }
}

// =============================================================================
// Transformation Tests
// =============================================================================

test "map p transforms value" {
    let parser: fn(Input) -> ParseResult = map_p(digit(), fn(v: Value) -> Value {
        let c: char = unwrap_char(v)
        return VString("digit:" + to_string(c))
    })
    let result: ParseResult = run(parser, "5abc")
    match result {
        Success(v, _) => {
            assert(unwrap_string(v) == "digit:5", "should transform value")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "map2 combines two" {
    let parser: fn(Input) -> ParseResult = map2(
        char_p('a'),
        char_p('b'),
        fn(a: Value, b: Value) -> Value {
            return VString(to_string(unwrap_char(a)) + to_string(unwrap_char(b)))
        }
    )
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, _) => {
            assert(unwrap_string(v) == "ab", "should combine to 'ab'")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "map3 combines three" {
    let parser: fn(Input) -> ParseResult = map3(
        char_p('a'),
        char_p('b'),
        char_p('c'),
        fn(a: Value, b: Value, c: Value) -> Value {
            return VString(to_string(unwrap_char(a)) + to_string(unwrap_char(b)) + to_string(unwrap_char(c)))
        }
    )
    let result: ParseResult = run(parser, "abcd")
    match result {
        Success(v, _) => {
            assert(unwrap_string(v) == "abc", "should combine to 'abc'")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "replace p replaces value" {
    let parser: fn(Input) -> ParseResult = replace_p(char_p('x'), VInt(42i64))
    let result: ParseResult = run(parser, "xyz")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 42i64, "should replace with 42")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

// =============================================================================
// Repetition Tests
// =============================================================================

test "many zero matches" {
    let parser: fn(Input) -> ParseResult = many(digit())
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, rest) => {
            assert(std.list.length(unwrap_list(v)) == 0, "should return empty list")
            assert(rest.pos.offset == 0, "should not consume input")
        }
        Failure(_) => {
            assert(false, "many should never fail")
        }
    }
}

test "many multiple matches" {
    let parser: fn(Input) -> ParseResult = many(digit())
    let result: ParseResult = run(parser, "123abc")
    match result {
        Success(v, rest) => {
            assert(std.list.length(unwrap_list(v)) == 3, "should parse 3 digits")
            assert(rest.pos.offset == 3, "should consume 3 chars")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "many1 requires one" {
    let parser: fn(Input) -> ParseResult = many1(digit())
    let result: ParseResult = run(parser, "123abc")
    match result {
        Success(v, _) => {
            assert(std.list.length(unwrap_list(v)) == 3, "should parse 3 digits")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "many1 empty fails" {
    let parser: fn(Input) -> ParseResult = many1(digit())
    let result: ParseResult = run(parser, "abc")
    assert(is_failure(result), "many1 should fail with zero matches")
}

test "count p exact" {
    let parser: fn(Input) -> ParseResult = count_p(3, letter())
    let result: ParseResult = run(parser, "abcdef")
    match result {
        Success(v, rest) => {
            assert(std.list.length(unwrap_list(v)) == 3, "should parse exactly 3")
            assert(rest.pos.offset == 3, "should consume 3 chars")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "count p not enough" {
    let parser: fn(Input) -> ParseResult = count_p(5, letter())
    let result: ParseResult = run(parser, "abc")
    assert(is_failure(result), "count should fail if not enough")
}

test "sep by empty" {
    let parser: fn(Input) -> ParseResult = sep_by(digit(), char_p(','))
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, rest) => {
            assert(std.list.length(unwrap_list(v)) == 0, "should return empty list")
            assert(rest.pos.offset == 0, "should not consume input")
        }
        Failure(_) => {
            assert(false, "sep_by should never fail")
        }
    }
}

test "sep by one item" {
    let parser: fn(Input) -> ParseResult = sep_by(digit(), char_p(','))
    let result: ParseResult = run(parser, "5abc")
    match result {
        Success(v, _) => {
            assert(std.list.length(unwrap_list(v)) == 1, "should parse one item")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "sep by multiple items" {
    let parser: fn(Input) -> ParseResult = sep_by(digit(), char_p(','))
    let result: ParseResult = run(parser, "1,2,3abc")
    match result {
        Success(v, rest) => {
            assert(std.list.length(unwrap_list(v)) == 3, "should parse 3 items")
            assert(rest.pos.offset == 5, "should consume '1,2,3'")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "sep by1 requires one" {
    let parser: fn(Input) -> ParseResult = sep_by1(digit(), char_p(','))
    let result: ParseResult = run(parser, "abc")
    assert(is_failure(result), "sep_by1 should fail with zero items")
}

test "end by with trailing" {
    let parser: fn(Input) -> ParseResult = end_by(digit(), char_p(';'))
    let result: ParseResult = run(parser, "1;2;3;abc")
    match result {
        Success(v, rest) => {
            assert(std.list.length(unwrap_list(v)) == 3, "should parse 3 items")
            assert(rest.pos.offset == 6, "should consume '1;2;3;'")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

// =============================================================================
// Lookahead Tests
// =============================================================================

test "lookahead no consume" {
    let parser: fn(Input) -> ParseResult = lookahead(char_p('a'))
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, rest) => {
            assert(unwrap_char(v) == 'a', "should return 'a'")
            assert(rest.pos.offset == 0, "should not consume input")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "lookahead fails" {
    let parser: fn(Input) -> ParseResult = lookahead(char_p('x'))
    let result: ParseResult = run(parser, "abc")
    assert(is_failure(result), "lookahead should fail if parser fails")
}

test "not followed by success" {
    let parser: fn(Input) -> ParseResult = not_followed_by(char_p('x'))
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(_, rest) => {
            assert(rest.pos.offset == 0, "should not consume input")
        }
        Failure(_) => {
            assert(false, "should succeed when parser fails")
        }
    }
}

test "not followed by failure" {
    let parser: fn(Input) -> ParseResult = not_followed_by(char_p('a'))
    let result: ParseResult = run(parser, "abc")
    assert(is_failure(result), "should fail when parser succeeds")
}

test "try p backtracks" {
    let failing_parser: fn(Input) -> ParseResult = and_then(
        char_p('a'),
        fn(_: Value) -> fn(Input) -> ParseResult { return char_p('x') }
    )
    let parser: fn(Input) -> ParseResult = try_p(failing_parser)
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(_, _) => {
            assert(false, "should fail")
        }
        Failure(e) => {
            assert(e.position.offset == 0, "error position should be reset to start")
        }
    }
}

// =============================================================================
// Error Enhancement Tests
// =============================================================================

test "label p replaces expected" {
    let parser: fn(Input) -> ParseResult = label_p(digit(), "number")
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(_, _) => {
            assert(false, "should fail")
        }
        Failure(e) => {
            assert(std.list.length(e.expected) == 1, "should have one expected")
            match e.expected {
                Cons(Custom(name), Nil) => {
                    assert(name == "number", "expected should be 'number'")
                }
                _ => { assert(false, "expected should be Custom") }
            }
        }
    }
}

test "context p adds context" {
    let parser: fn(Input) -> ParseResult = context_p(digit(), "parsing age")
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(_, _) => {
            assert(false, "should fail")
        }
        Failure(e) => {
            assert(std.list.length(e.context) == 1, "should have one context")
            match e.context {
                Cons(ctx, Nil) => {
                    assert(ctx == "parsing age", "context should match")
                }
                _ => { assert(false, "context should have one item") }
            }
        }
    }
}

// =============================================================================
// Recursive Parser Tests
// =============================================================================

test "lazy p defers construction" {
    let parser: fn(Input) -> ParseResult = lazy_p(fn() -> fn(Input) -> ParseResult {
        return char_p('a')
    })
    let result: ParseResult = run(parser, "abc")
    assert(is_success(result), "should succeed")
}

// =============================================================================
// Integration Tests
// =============================================================================

test "parse comma separated digits" {
    let parser: fn(Input) -> ParseResult = sep_by(digit(), char_p(','))
    let result: ParseResult = run(parser, "1,2,3")
    match result {
        Success(v, _) => {
            assert(std.list.length(unwrap_list(v)) == 3, "should parse 3 items")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "parse key value" {
    // Parse key=value where both are letters
    let word: fn(Input) -> ParseResult = map_p(many1(letter()), fn(v: Value) -> Value {
        return VString(value_chars_to_string(v))
    })
    let parser: fn(Input) -> ParseResult = map3(
        word,
        char_p('='),
        word,
        fn(key: Value, _eq: Value, val: Value) -> Value {
            return VPair(key, val)
        }
    )
    let result: ParseResult = run(parser, "foo=bar")
    match result {
        Success(v, _) => {
            match v {
                VPair(k, val) => {
                    assert(unwrap_string(k) == "foo", "key should be 'foo'")
                    assert(unwrap_string(val) == "bar", "value should be 'bar'")
                }
                _ => { assert(false, "should be VPair") }
            }
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

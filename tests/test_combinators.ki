let test_or_else_first_succeeds: fn() -> void = fn() -> void {
    let parser: Parser[char] = or_else[char](char_p('a'), char_p('b'))
    let result: ParseResult[char] = run[char](parser, "abc")
    match result {
        Success { value: c, remaining: _ } => {
            assert(c == 'a', "should return 'a'")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_or_else_second_succeeds: fn() -> void = fn() -> void {
    let parser: Parser[char] = or_else[char](char_p('x'), char_p('a'))
    let result: ParseResult[char] = run[char](parser, "abc")
    match result {
        Success { value: c, remaining: _ } => {
            assert(c == 'a', "should return 'a' from second parser")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_or_else_both_fail_merges_errors: fn() -> void = fn() -> void {
    let parser: Parser[char] = or_else[char](char_p('x'), char_p('y'))
    let result: ParseResult[char] = run[char](parser, "abc")
    match result {
        Success { value: _, remaining: _ } => {
            assert(false, "should fail")
        }
        Failure { error: e } => {
            // Should have merged expected from both parsers
            assert(length[Expected](e.expected) == 2, "should merge expected lists")
        }
    }
    return
}

let test_choice_empty_list: fn() -> void = fn() -> void {
    let parsers: List[Parser[char]] = Nil
    let parser: Parser[char] = choice[char](parsers)
    let result: ParseResult[char] = run[char](parser, "abc")
    assert(is_failure[char](result), "choice of empty list should fail")
    return
}

let test_choice_first_match: fn() -> void = fn() -> void {
    let parsers: List[Parser[char]] = Cons(char_p('a'), Cons(char_p('b'), Cons(char_p('c'), Nil)))
    let parser: Parser[char] = choice[char](parsers)
    let result: ParseResult[char] = run[char](parser, "abc")
    match result {
        Success { value: c, remaining: _ } => {
            assert(c == 'a', "should match first")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_choice_later_match: fn() -> void = fn() -> void {
    let parsers: List[Parser[char]] = Cons(char_p('x'), Cons(char_p('y'), Cons(char_p('a'), Nil)))
    let parser: Parser[char] = choice[char](parsers)
    let result: ParseResult[char] = run[char](parser, "abc")
    match result {
        Success { value: c, remaining: _ } => {
            assert(c == 'a', "should match third")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_optional_present: fn() -> void = fn() -> void {
    let parser: Parser[Option[char]] = optional[char](char_p('a'))
    let result: ParseResult[Option[char]] = run[Option[char]](parser, "abc")
    match result {
        Success { value: opt, remaining: _ } => {
            match opt {
                Some(c) => { assert(c == 'a', "should be Some('a')") }
                None => { assert(false, "should be Some") }
            }
        }
        Failure { error: _ } => {
            assert(false, "optional should never fail")
        }
    }
    return
}

let test_optional_absent: fn() -> void = fn() -> void {
    let parser: Parser[Option[char]] = optional[char](char_p('x'))
    let result: ParseResult[Option[char]] = run[Option[char]](parser, "abc")
    match result {
        Success { value: opt, remaining: rest } => {
            match opt {
                Some(_) => { assert(false, "should be None") }
                None => { assert(rest.pos.offset == 0, "should not consume input") }
            }
        }
        Failure { error: _ } => {
            assert(false, "optional should never fail")
        }
    }
    return
}


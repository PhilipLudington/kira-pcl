    match result {
        Success { value: list, remaining: rest } => {
            assert(length[char](list) == 3, "should parse exactly 3")
            assert(rest.pos.offset == 3, "should consume 3 chars")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_count_not_enough: fn() -> void = fn() -> void {
    let parser: Parser[List[char]] = count[char](5, letter())
    let result: ParseResult[List[char]] = run[List[char]](parser, "abc")
    assert(is_failure[List[char]](result), "count should fail if not enough")

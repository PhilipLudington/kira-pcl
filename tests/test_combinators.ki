        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

// =============================================================================
// Lookahead Tests
// =============================================================================

let test_lookahead_no_consume: fn() -> void = fn() -> void {
    let parser: Parser[char] = lookahead[char](char_p('a'))
    let result: ParseResult[char] = run[char](parser, "abc")
    match result {
        Success { value: c, remaining: rest } => {
            assert(c == 'a', "should return 'a'")
            assert(rest.pos.offset == 0, "should not consume input")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_lookahead_fails: fn() -> void = fn() -> void {
    let parser: Parser[char] = lookahead[char](char_p('x'))
    let result: ParseResult[char] = run[char](parser, "abc")
    assert(is_failure[char](result), "lookahead should fail if parser fails")
    return
}

let test_not_followed_by_success: fn() -> void = fn() -> void {
    let parser: Parser[void] = not_followed_by[char](char_p('x'))
    let result: ParseResult[void] = run[void](parser, "abc")
    match result {
        Success { value: _, remaining: rest } => {
            assert(rest.pos.offset == 0, "should not consume input")
        }
        Failure { error: _ } => {
            assert(false, "should succeed when parser fails")
        }
    }
    return
}

let test_not_followed_by_failure: fn() -> void = fn() -> void {
    let parser: Parser[void] = not_followed_by[char](char_p('a'))
    let result: ParseResult[void] = run[void](parser, "abc")
    assert(is_failure[void](result), "should fail when parser succeeds")
    return
}

let test_try_p_backtracks: fn() -> void = fn() -> void {
    // Create a parser that consumes input then fails
    let failing_parser: Parser[char] = and_then[char, char](
        char_p('a'),
        fn(_: char) -> Parser[char] { return char_p('x') }
    )
    let parser: Parser[char] = try_p[char](failing_parser)
    let result: ParseResult[char] = run[char](parser, "abc")
    match result {
        Success { value: _, remaining: _ } => {
            assert(false, "should fail")
        }
        Failure { error: e } => {
            // try_p should reset position to start
            assert(e.position.offset == 0, "error position should be reset to start")
        }
    }
    return
}

// =============================================================================
// Error Enhancement Tests
// =============================================================================

let test_label_replaces_expected: fn() -> void = fn() -> void {
    let parser: Parser[char] = label[char](digit(), "number")
    let result: ParseResult[char] = run[char](parser, "abc")
    match result {
        Success { value: _, remaining: _ } => {
            assert(false, "should fail")
        }
        Failure { error: e } => {
            assert(length[Expected](e.expected) == 1, "should have one expected")
            match e.expected {
                Cons(Custom(name), Nil) => {
                    assert(name == "number", "expected should be 'number'")
                }
                _ => { assert(false, "expected should be Custom") }
            }
        }
    }
    return
}

let test_context_adds_context: fn() -> void = fn() -> void {
    let parser: Parser[char] = context[char](digit(), "parsing age")
    let result: ParseResult[char] = run[char](parser, "abc")
    match result {
        Success { value: _, remaining: _ } => {
            assert(false, "should fail")
        }
        Failure { error: e } => {
            assert(length[string](e.context) == 1, "should have one context")
            match e.context {
                Cons(ctx, Nil) => {
                    assert(ctx == "parsing age", "context should match")
                }
                _ => { assert(false, "context should have one item") }
            }
        }
    }
    return
}

// =============================================================================
// Recursive Parser Tests
// =============================================================================

let test_lazy_defers_construction: fn() -> void = fn() -> void {
    var called: bool = false
    let parser: Parser[char] = lazy[char](fn() -> Parser[char] {
        called = true
        return char_p('a')
    })

    // Parser construction should not call thunk yet
    assert(not called, "thunk should not be called during construction")

    // Running the parser should call the thunk
    let result: ParseResult[char] = run[char](parser, "abc")
    assert(called, "thunk should be called during parsing")
    assert(is_success[char](result), "should succeed")
    return
}

let test_fix_recursive_parser: fn() -> void = fn() -> void {
    // Parse nested parentheses: (), (()), ((())), etc.
    let paren_parser: Parser[i32] = fix[i32](fn(self: Parser[i32]) -> Parser[i32] {
        return or_else[i32](
            // Base case: empty parens = depth 0
            replace[string, i32](string_p("()"), 0),
            // Recursive case: (inner) = inner + 1
            map[i32, i32](
                between[char, i32, char](char_p('('), self, char_p(')')),
                fn(inner: i32) -> i32 { return inner + 1 }
            )
        )
    })

    let result1: ParseResult[i32] = run[i32](paren_parser, "()")
    match result1 {
        Success { value: n, remaining: _ } => { assert(n == 0, "() should be depth 0") }
        Failure { error: _ } => { assert(false, "should succeed") }
    }

    let result2: ParseResult[i32] = run[i32](paren_parser, "(())")
    match result2 {
        Success { value: n, remaining: _ } => { assert(n == 1, "(()) should be depth 1") }
        Failure { error: _ } => { assert(false, "should succeed") }
    }

    let result3: ParseResult[i32] = run[i32](paren_parser, "((()))")
    match result3 {
        Success { value: n, remaining: _ } => { assert(n == 2, "((())) should be depth 2") }
        Failure { error: _ } => { assert(false, "should succeed") }
    }
    return
}

// =============================================================================
// Integration Tests
// =============================================================================

let test_parse_comma_separated_numbers: fn() -> void = fn() -> void {
    let num_parser: Parser[i32] = map[List[char], i32](
        many1[char](digit()),
        fn(chars: List[char]) -> i32 {
            return std.string.parse_i32(chars_to_string(chars))
        }
    )
    let parser: Parser[List[i32]] = sep_by[i32, char](num_parser, char_p(','))
    let result: ParseResult[List[i32]] = run[List[i32]](parser, "1,23,456")
    match result {
        Success { value: nums, remaining: _ } => {
            assert(length[i32](nums) == 3, "should parse 3 numbers")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_parse_key_value: fn() -> void = fn() -> void {
    let identifier: Parser[string] = map[List[char], string](
        many1[char](letter()),
        fn(chars: List[char]) -> string { return chars_to_string(chars) }
    )
    let parser: Parser[(string, string)] = map3[string, char, string, (string, string)](
        identifier,
        char_p('='),
        identifier,
        fn(key: string, _: char, value: string) -> (string, string) {
            return (key, value)
        }
    )
    let result: ParseResult[(string, string)] = run[(string, string)](parser, "foo=bar")
    match result {
        Success { value: pair, remaining: _ } => {
            let (key, value): (string, string) = pair
            assert(key == "foo", "key should be 'foo'")
            assert(value == "bar", "value should be 'bar'")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

/// Tests for the combinators module
///
/// Tests cover:
/// - Sequencing combinators
/// - Alternation combinators
/// - Transformation combinators
/// - Repetition combinators
/// - Lookahead combinators
/// - Error enhancement
/// - Recursive parser support

import src.types
import src.primitives
import src.combinators

// =============================================================================
// Sequencing Tests
// =============================================================================

let test_and_then_success: fn() -> void = fn() -> void {
    let parser: Parser[string] = and_then[char, string](
        char_p('a'),
        fn(c: char) -> Parser[string] {
            return map[char, string](char_p('b'), fn(c2: char) -> string {
                return chars_to_string(Cons(c, Cons(c2, Nil)))
            })
        }
    )
    let result: ParseResult[string] = run[string](parser, "abc")
    match result {
        Success { value: s, remaining: _ } => {
            assert(s == "ab", "should parse 'ab'")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_and_then_first_fails: fn() -> void = fn() -> void {
    let parser: Parser[char] = and_then[char, char](
        char_p('x'),
        fn(_: char) -> Parser[char] { return char_p('y') }
    )
    let result: ParseResult[char] = run[char](parser, "abc")
    assert(is_failure[char](result), "should fail when first parser fails")
    return
}

let test_and_then_second_fails: fn() -> void = fn() -> void {
    let parser: Parser[char] = and_then[char, char](
        char_p('a'),
        fn(_: char) -> Parser[char] { return char_p('x') }
    )
    let result: ParseResult[char] = run[char](parser, "abc")
    assert(is_failure[char](result), "should fail when second parser fails")
    return
}

let test_seq_left_keeps_left: fn() -> void = fn() -> void {
    let parser: Parser[char] = seq_left[char, char](char_p('a'), char_p('b'))
    let result: ParseResult[char] = run[char](parser, "abc")
    match result {
        Success { value: c, remaining: rest } => {
            assert(c == 'a', "should return 'a'")
            assert(rest.pos.offset == 2, "should consume both chars")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_seq_right_keeps_right: fn() -> void = fn() -> void {
    let parser: Parser[char] = seq_right[char, char](char_p('a'), char_p('b'))
    let result: ParseResult[char] = run[char](parser, "abc")
    match result {
        Success { value: c, remaining: rest } => {
            assert(c == 'b', "should return 'b'")
            assert(rest.pos.offset == 2, "should consume both chars")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_seq_pair_keeps_both: fn() -> void = fn() -> void {
    let parser: Parser[(char, char)] = seq_pair[char, char](char_p('a'), char_p('b'))
    let result: ParseResult[(char, char)] = run[(char, char)](parser, "abc")
    match result {
        Success { value: pair, remaining: _ } => {
            let (first, second): (char, char) = pair
            assert(first == 'a', "first should be 'a'")
            assert(second == 'b', "second should be 'b'")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_between_extracts_middle: fn() -> void = fn() -> void {
    let parser: Parser[char] = between[char, char, char](
        char_p('('),
        char_p('x'),
        char_p(')')
    )
    let result: ParseResult[char] = run[char](parser, "(x)")
    match result {
        Success { value: c, remaining: rest } => {
            assert(c == 'x', "should extract 'x'")
            assert(rest.pos.offset == 3, "should consume all three chars")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}


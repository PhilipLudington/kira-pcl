let test_many_zero_matches: fn() -> void = fn() -> void {
    let parser: Parser[List[char]] = many[char](digit())
    let result: ParseResult[List[char]] = run[List[char]](parser, "abc")
    match result {
        Success { value: list, remaining: rest } => {
            assert(length[char](list) == 0, "should return empty list")
            assert(rest.pos.offset == 0, "should not consume input")
        }
        Failure { error: _ } => {
            assert(false, "many should never fail")
        }
    }
    return
}

let test_many_multiple_matches: fn() -> void = fn() -> void {
    let parser: Parser[List[char]] = many[char](digit())
    let result: ParseResult[List[char]] = run[List[char]](parser, "123abc")
    match result {
        Success { value: list, remaining: rest } => {
            assert(length[char](list) == 3, "should parse 3 digits")
            assert(rest.pos.offset == 3, "should consume 3 chars")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_many1_requires_one: fn() -> void = fn() -> void {
    let parser: Parser[List[char]] = many1[char](digit())
    let result: ParseResult[List[char]] = run[List[char]](parser, "123abc")

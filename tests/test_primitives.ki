// Tests for the primitives module

import src.types
import src.primitives

// =============================================================================
// any_char Tests
// =============================================================================

fn test_any_char_success() -> void {
    let parser: fn(Input) -> ParseResult = any_char()
    let result: ParseResult = run(parser, "hello")
    match result {
        Success(v, rest) => {
            assert(unwrap_char(v) == 'h', "should parse 'h'")
            assert(rest.pos.offset == 1, "offset should advance")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
    return
}

fn test_any_char_empty_input() -> void {
    let parser: fn(Input) -> ParseResult = any_char()
    let result: ParseResult = run(parser, "")
    assert(is_failure(result), "should fail on empty input")
    return
}

// =============================================================================
// char_p Tests
// =============================================================================

fn test_char_p_match() -> void {
    let parser: fn(Input) -> ParseResult = char_p('x')
    let result: ParseResult = run(parser, "xyz")
    match result {
        Success(v, rest) => {
            assert(unwrap_char(v) == 'x', "should parse 'x'")
            assert(rest.pos.offset == 1, "offset should advance")
            assert(rest.pos.column == 2, "column should advance")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
    return
}

fn test_char_p_no_match() -> void {
    let parser: fn(Input) -> ParseResult = char_p('x')
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(_, _) => {
            assert(false, "should fail")
        }
        Failure(e) => {
            assert(e.position.offset == 0, "error should be at start")
            match e.actual {
                Some(c) => { assert(c == 'a', "actual should be 'a'") }
                None => { assert(false, "actual should be Some") }
            }
        }
    }
    return
}

fn test_char_p_empty_input() -> void {
    let parser: fn(Input) -> ParseResult = char_p('x')
    let result: ParseResult = run(parser, "")
    match result {
        Success(_, _) => {
            assert(false, "should fail")
        }
        Failure(e) => {
            match e.actual {
                Some(_) => { assert(false, "actual should be None for empty") }
                None => { return }
            }
        }
    }
}

// =============================================================================
// satisfy Tests
// =============================================================================

fn test_satisfy_digit() -> void {
    let parser: fn(Input) -> ParseResult = satisfy(is_digit, "digit")
    let result: ParseResult = run(parser, "5abc")
    match result {
        Success(v, _) => {
            assert(unwrap_char(v) == '5', "should parse '5'")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
    return
}

fn test_satisfy_custom_predicate() -> void {
    let is_vowel: fn(char) -> bool = fn(c: char) -> bool {
        return c == 'a' or c == 'e' or c == 'i' or c == 'o' or c == 'u'
    }
    let parser: fn(Input) -> ParseResult = satisfy(is_vowel, "vowel")

    let result1: ParseResult = run(parser, "apple")
    assert(is_success(result1), "should match 'a'")

    let result2: ParseResult = run(parser, "xyz")
    assert(is_failure(result2), "should fail on 'x'")
    return
}

// =============================================================================
// Character Class Parser Tests
// =============================================================================

fn test_digit_parses_digits() -> void {
    let parser: fn(Input) -> ParseResult = digit()

    assert(is_success(run(parser, "0")), "should parse '0'")
    assert(is_success(run(parser, "9")), "should parse '9'")
    assert(is_failure(run(parser, "a")), "should fail on letter")
    return
}

fn test_letter_parses_letters() -> void {
    let parser: fn(Input) -> ParseResult = letter()

    assert(is_success(run(parser, "a")), "should parse 'a'")
    assert(is_success(run(parser, "Z")), "should parse 'Z'")
    assert(is_failure(run(parser, "5")), "should fail on digit")
    return
}

fn test_alphanumeric() -> void {
    let parser: fn(Input) -> ParseResult = alphanumeric()

    assert(is_success(run(parser, "a")), "should parse letter")
    assert(is_success(run(parser, "5")), "should parse digit")
    assert(is_failure(run(parser, "!")), "should fail on special char")
    return
}

fn test_whitespace() -> void {
    let parser: fn(Input) -> ParseResult = whitespace()

    assert(is_success(run(parser, " ")), "should parse space")
    assert(is_success(run(parser, "\t")), "should parse tab")
    assert(is_success(run(parser, "\n")), "should parse newline")
    assert(is_failure(run(parser, "a")), "should fail on letter")
    return
}

fn test_one_of_matches() -> void {
    let parser: fn(Input) -> ParseResult = one_of("aeiou")

    assert(is_success(run(parser, "a")), "should match 'a'")
    assert(is_success(run(parser, "e")), "should match 'e'")
    assert(is_success(run(parser, "u")), "should match 'u'")
    assert(is_failure(run(parser, "x")), "should fail on 'x'")
    return
}

fn test_none_of_excludes() -> void {
    let parser: fn(Input) -> ParseResult = none_of("aeiou")

    assert(is_failure(run(parser, "a")), "should fail on 'a'")
    assert(is_failure(run(parser, "e")), "should fail on 'e'")
    assert(is_success(run(parser, "x")), "should match 'x'")
    assert(is_success(run(parser, "z")), "should match 'z'")
    return
}

// =============================================================================
// string_p Tests
// =============================================================================

fn test_string_p_exact_match() -> void {
    let parser: fn(Input) -> ParseResult = string_p("hello")
    let result: ParseResult = run(parser, "hello world")
    match result {
        Success(v, rest) => {
            assert(unwrap_string(v) == "hello", "should parse 'hello'")
            assert(rest.pos.offset == 5, "offset should advance by 5")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
    return
}

fn test_string_p_partial_no_match() -> void {
    let parser: fn(Input) -> ParseResult = string_p("hello")
    let result: ParseResult = run(parser, "help me")
    assert(is_failure(result), "should fail on partial match")
    return
}

fn test_string_p_empty_expected() -> void {
    let parser: fn(Input) -> ParseResult = string_p("")
    let result: ParseResult = run(parser, "anything")
    match result {
        Success(v, rest) => {
            assert(unwrap_string(v) == "", "should parse empty string")
            assert(rest.pos.offset == 0, "offset should not advance")
        }
        Failure(_) => {
            assert(false, "empty string should always succeed")
        }
    }
    return
}

// =============================================================================
// eof Tests
// =============================================================================

fn test_eof_at_end() -> void {
    let parser: fn(Input) -> ParseResult = eof()
    let result: ParseResult = run(parser, "")
    assert(is_success(result), "should succeed at end of input")
    return
}

fn test_eof_not_at_end() -> void {
    let parser: fn(Input) -> ParseResult = eof()
    let result: ParseResult = run(parser, "remaining")
    match result {
        Success(_, _) => {
            assert(false, "should fail when input remains")
        }
        Failure(e) => {
            match e.actual {
                Some(c) => { assert(c == 'r', "actual should show first remaining char") }
                None => { assert(false, "actual should be Some") }
            }
        }
    }
    return
}

// =============================================================================
// pure_p Tests
// =============================================================================

fn test_pure_p_always_succeeds() -> void {
    let parser: fn(Input) -> ParseResult = pure_p(VInt(42i64))
    let result: ParseResult = run(parser, "anything")
    match result {
        Success(v, rest) => {
            assert(unwrap_int(v) == 42i64, "value should be 42")
            assert(rest.pos.offset == 0, "should not consume input")
        }
        Failure(_) => {
            assert(false, "pure should never fail")
        }
    }
    return
}

fn test_pure_p_on_empty() -> void {
    let parser: fn(Input) -> ParseResult = pure_p(VString("hello"))
    let result: ParseResult = run(parser, "")
    assert(is_success(result), "pure should succeed on empty input")
    return
}

// =============================================================================
// fail_p Tests
// =============================================================================

fn test_fail_p_always_fails() -> void {
    let parser: fn(Input) -> ParseResult = fail_p("expected something else")
    let result: ParseResult = run(parser, "anything")
    match result {
        Success(_, _) => {
            assert(false, "fail should never succeed")
        }
        Failure(e) => {
            assert(e.position.offset == 0, "error should be at start")
        }
    }
    return
}

// =============================================================================
// run/parse Tests
// =============================================================================

fn test_run_returns_parse_result() -> void {
    let parser: fn(Input) -> ParseResult = char_p('x')
    let result: ParseResult = run(parser, "xyz")
    assert(is_success(result), "run should return success")
    return
}

fn test_parse_returns_result_ok() -> void {
    let parser: fn(Input) -> ParseResult = char_p('x')
    let result: Result[Value, ParseError] = parse(parser, "xyz")
    match result {
        Ok(v) => { assert(unwrap_char(v) == 'x', "should return 'x'") }
        Err(_) => { assert(false, "should be Ok") }
    }
    return
}

fn test_parse_returns_result_err() -> void {
    let parser: fn(Input) -> ParseResult = char_p('x')
    let result: Result[Value, ParseError] = parse(parser, "abc")
    match result {
        Ok(_) => { assert(false, "should be Err") }
        Err(e) => { assert(e.position.offset == 0, "error should be at start") }
    }
    return
}

// =============================================================================
// Position Tracking Tests
// =============================================================================

fn test_position_advances_column() -> void {
    let parser: fn(Input) -> ParseResult = any_char()
    let result1: ParseResult = run(parser, "abc")
    match result1 {
        Success(_, rest1) => {
            let result2: ParseResult = parser(rest1)
            match result2 {
                Success(_, rest2) => {
                    assert(rest2.pos.column == 3, "column should be 3")
                    assert(rest2.pos.line == 1, "line should still be 1")
                }
                Failure(_) => { assert(false, "should succeed") }
            }
        }
        Failure(_) => { assert(false, "should succeed") }
    }
    return
}

fn test_position_advances_line_on_newline() -> void {
    let parser: fn(Input) -> ParseResult = any_char()
    let input: Input = input_new("a\nb")

    let result1: ParseResult = parser(input)
    match result1 {
        Success(_, rest1) => {
            let result2: ParseResult = parser(rest1)
            match result2 {
                Success(v, rest2) => {
                    assert(unwrap_char(v) == '\n', "should parse newline")
                    assert(rest2.pos.line == 2, "line should be 2")
                    assert(rest2.pos.column == 1, "column should reset to 1")
                }
                Failure(_) => { assert(false, "should succeed") }
            }
        }
        Failure(_) => { assert(false, "should succeed") }
    }
    return
}

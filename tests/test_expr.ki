// Tests for the expression parsing module

import src.types
import src.primitives
import src.combinators
import src.lexer
import src.expr

// =============================================================================
// Chain Combinator Tests
// =============================================================================

test "chainl1 op single term" {
    let add_op: Operator = infixl_op(symbol("+"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) + unwrap_int(b))
    })
    let parser: fn(Input) -> ParseResult = chainl1_op(integer(), Cons(add_op, Nil))
    let result: ParseResult = run(parser, "42 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 42i64, "single term should return 42")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "chainl1 op two terms" {
    let add_op: Operator = infixl_op(symbol("+"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) + unwrap_int(b))
    })
    let parser: fn(Input) -> ParseResult = chainl1_op(integer(), Cons(add_op, Nil))
    let result: ParseResult = run(parser, "1 + 2 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 3i64, "1 + 2 should equal 3")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "chainl1 op left associative" {
    // Test: 10 - 3 - 2 should be ((10 - 3) - 2) = 5
    let sub_op: Operator = infixl_op(symbol("-"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) - unwrap_int(b))
    })
    let parser: fn(Input) -> ParseResult = chainl1_op(integer(), Cons(sub_op, Nil))
    let result: ParseResult = run(parser, "10 - 3 - 2 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 5i64, "10 - 3 - 2 should be 5 (left associative)")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "chainr1 op right associative" {
    // Test: 10 - 3 - 2 = 10 - (3 - 2) = 10 - 1 = 9
    let sub_op: Operator = infixr_op(symbol("-"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) - unwrap_int(b))
    })
    let parser: fn(Input) -> ParseResult = chainr1_op(integer(), Cons(sub_op, Nil))
    let result: ParseResult = run(parser, "10 - 3 - 2 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 9i64, "10 - 3 - 2 should be 9 (right associative)")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "chainl1 op multiple ops" {
    let add_op: Operator = infixl_op(symbol("+"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) + unwrap_int(b))
    })
    let sub_op: Operator = infixl_op(symbol("-"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) - unwrap_int(b))
    })
    let parser: fn(Input) -> ParseResult = chainl1_op(integer(), Cons(add_op, Cons(sub_op, Nil)))
    let result: ParseResult = run(parser, "10 + 5 - 3 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 12i64, "10 + 5 - 3 should be 12")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

// =============================================================================
// Expression Parser Builder Tests
// =============================================================================

test "add operators single level" {
    let mul_op: Operator = infixl_op(symbol("*"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) * unwrap_int(b))
    })
    let parser: fn(Input) -> ParseResult = add_operators(integer(), Cons(mul_op, Nil))
    let result: ParseResult = run(parser, "2 * 3 * 4 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 24i64, "2 * 3 * 4 should be 24")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "build expr parser precedence" {
    let add_op: Operator = infixl_op(symbol("+"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) + unwrap_int(b))
    })
    let sub_op: Operator = infixl_op(symbol("-"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) - unwrap_int(b))
    })
    let mul_op: Operator = infixl_op(symbol("*"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) * unwrap_int(b))
    })
    let div_op: Operator = infixl_op(symbol("/"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) / unwrap_int(b))
    })

    // Table: highest precedence first
    let mul_level: List[Operator] = Cons(mul_op, Cons(div_op, Nil))
    let add_level: List[Operator] = Cons(add_op, Cons(sub_op, Nil))
    let table: List[List[Operator]] = Cons(mul_level, Cons(add_level, Nil))
    let parser: fn(Input) -> ParseResult = build_expr_parser(table, integer())

    // Test: 2 + 3 * 4 = 2 + 12 = 14
    let result: ParseResult = run(parser, "2 + 3 * 4 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 14i64, "2 + 3 * 4 should be 14")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "build expr parser associativity" {
    let sub_op: Operator = infixl_op(symbol("-"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) - unwrap_int(b))
    })
    let level: List[Operator] = Cons(sub_op, Nil)
    let table: List[List[Operator]] = Cons(level, Nil)
    let parser: fn(Input) -> ParseResult = build_expr_parser(table, integer())

    // 100 - 30 - 10 = ((100 - 30) - 10) = 60
    let result: ParseResult = run(parser, "100 - 30 - 10 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 60i64, "100 - 30 - 10 should be 60")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "non assoc operator" {
    let eq_op: Operator = infix_none_op(symbol("=="), fn(a: Value, b: Value) -> Value {
        if unwrap_int(a) == unwrap_int(b) {
            return VBool(true)
        }
        return VBool(false)
    })
    let level: List[Operator] = Cons(eq_op, Nil)
    let table: List[List[Operator]] = Cons(level, Nil)
    let parser: fn(Input) -> ParseResult = build_expr_parser(table, integer())

    // 3 == 3 should work
    let result: ParseResult = run(parser, "3 == 3 ")
    match result {
        Success(v, _) => {
            assert(unwrap_bool(v), "3 == 3 should be true")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

// =============================================================================
// Complex Expression Tests
// =============================================================================

test "complex expression" {
    let add_op: Operator = infixl_op(symbol("+"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) + unwrap_int(b))
    })
    let sub_op: Operator = infixl_op(symbol("-"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) - unwrap_int(b))
    })
    let mul_op: Operator = infixl_op(symbol("*"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) * unwrap_int(b))
    })
    let div_op: Operator = infixl_op(symbol("/"), fn(a: Value, b: Value) -> Value {
        return VInt(unwrap_int(a) / unwrap_int(b))
    })

    // Table: highest precedence first
    let mul_level: List[Operator] = Cons(mul_op, Cons(div_op, Nil))
    let add_level: List[Operator] = Cons(add_op, Cons(sub_op, Nil))
    let table: List[List[Operator]] = Cons(mul_level, Cons(add_level, Nil))
    let parser: fn(Input) -> ParseResult = build_expr_parser(table, integer())

    // Test: 1 + 2 * 3 - 4 / 2 = 1 + 6 - 2 = 5
    let result: ParseResult = run(parser, "1 + 2 * 3 - 4 / 2 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 5i64, "1 + 2 * 3 - 4 / 2 should be 5")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

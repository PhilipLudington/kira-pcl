        }
    }
    return
}

let test_postfix_single: fn() -> void = fn() -> void {
    // Factorial-like: 5! (but just double for testing)
    let bang: Parser[fn(i64) -> i64] = replace[string, fn(i64) -> i64](
        symbol("!"),
        fn(x: i64) -> i64 { return x * 2 }
    )
    let term: Parser[i64] = integer()
    let parser: Parser[i64] = postfix[i64](term, bang)
    let result: ParseResult[i64] = run[i64](parser, "5 ! ")
    match result {
        Success { value: n, remaining: _ } => {
            assert(n == 10, "5! should be 10")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_postfix_multiple: fn() -> void = fn() -> void {
    let bang: Parser[fn(i64) -> i64] = replace[string, fn(i64) -> i64](
        symbol("!"),
        fn(x: i64) -> i64 { return x * 2 }
    )
    let term: Parser[i64] = integer()
    let parser: Parser[i64] = postfix[i64](term, bang)
    let result: ParseResult[i64] = run[i64](parser, "3 ! ! ")
    match result {
        Success { value: n, remaining: _ } => {
            assert(n == 12, "3!! should be 12")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

// =============================================================================
// Complex Expression Tests
// =============================================================================

let test_complex_expression: fn() -> void = fn() -> void {
    let term: Parser[i64] = integer()

    // Build a complete arithmetic parser
    let add_op: Operator[i64] = infixl[i64](
        symbol("+"),
        fn(a: i64, b: i64) -> i64 { return a + b }
    )
    let sub_op: Operator[i64] = infixl[i64](
        symbol("-"),
        fn(a: i64, b: i64) -> i64 { return a - b }
    )
    let add_level: PrecLevel[i64] = Cons(add_op, Cons(sub_op, Nil))

    let mul_op: Operator[i64] = infixl[i64](
        symbol("*"),
        fn(a: i64, b: i64) -> i64 { return a * b }
    )
    let div_op: Operator[i64] = infixl[i64](
        symbol("/"),
        fn(a: i64, b: i64) -> i64 { return a / b }
    )
    let mul_level: PrecLevel[i64] = Cons(mul_op, Cons(div_op, Nil))

    let table: List[PrecLevel[i64]] = Cons(add_level, Cons(mul_level, Nil))
    let parser: Parser[i64] = build_expr_parser[i64](table, term)

    // Test: 1 + 2 * 3 - 4 / 2 = 1 + 6 - 2 = 5
    let result: ParseResult[i64] = run[i64](parser, "1 + 2 * 3 - 4 / 2 ")
    match result {
        Success { value: n, remaining: _ } => {
            assert(n == 5, "1 + 2 * 3 - 4 / 2 should be 5")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

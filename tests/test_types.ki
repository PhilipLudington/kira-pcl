/// Tests for the core types module
///
/// Tests cover:
/// - Position creation and advancement
/// - Input creation
/// - Error creation and merging
/// - ParseResult predicates
/// - List utilities
/// - String utilities

import src.types

// =============================================================================
// Position Tests
// =============================================================================

let test_position_new: fn() -> void = fn() -> void {
    let pos: Position = position_new(10, 2, 5)
    assert(pos.offset == 10, "offset should be 10")
    assert(pos.line == 2, "line should be 2")
    assert(pos.column == 5, "column should be 5")
    return
}

let test_advance_position_regular_char: fn() -> void = fn() -> void {
    let pos: Position = position_new(0, 1, 1)
    let new_pos: Position = advance_position(pos, 'a')
    assert(new_pos.offset == 1, "offset should advance by 1")
    assert(new_pos.line == 1, "line should stay 1")
    assert(new_pos.column == 2, "column should advance by 1")
    return
}

let test_advance_position_newline: fn() -> void = fn() -> void {
    let pos: Position = position_new(5, 1, 6)
    let new_pos: Position = advance_position(pos, '\n')
    assert(new_pos.offset == 6, "offset should advance by 1")
    assert(new_pos.line == 2, "line should advance to 2")
    assert(new_pos.column == 1, "column should reset to 1")
    return
}

let test_advance_position_by_string: fn() -> void = fn() -> void {
    let pos: Position = position_new(0, 1, 1)
    let new_pos: Position = advance_position_by_string(pos, "abc")
    assert(new_pos.offset == 3, "offset should be 3")
    assert(new_pos.line == 1, "line should stay 1")
    assert(new_pos.column == 4, "column should be 4")
    return
}

let test_advance_position_by_string_with_newline: fn() -> void = fn() -> void {
    let pos: Position = position_new(0, 1, 1)
    let new_pos: Position = advance_position_by_string(pos, "ab\ncd")
    assert(new_pos.offset == 5, "offset should be 5")
    assert(new_pos.line == 2, "line should be 2")
    assert(new_pos.column == 3, "column should be 3")
    return
}

// =============================================================================
// Input Tests
// =============================================================================

let test_input_new: fn() -> void = fn() -> void {
    let input: Input = input_new("hello world")
    assert(input.source == "hello world", "source should match")
    assert(input.pos.offset == 0, "offset should start at 0")
    assert(input.pos.line == 1, "line should start at 1")
    assert(input.pos.column == 1, "column should start at 1")
    return
}

let test_input_new_empty: fn() -> void = fn() -> void {
    let input: Input = input_new("")
    assert(input.source == "", "source should be empty")
    assert(input.pos.offset == 0, "offset should be 0")
    return
}

// =============================================================================
// Error Tests
// =============================================================================

let test_error_at_creates_error: fn() -> void = fn() -> void {
    let pos: Position = position_new(5, 2, 3)
    let err: ParseError = error_at(pos, Literal("x"), Some('y'))
    assert(err.position.offset == 5, "position offset should match")
    assert(err.position.line == 2, "position line should match")
    assert(length[Expected](err.expected) == 1, "should have one expected")
    match err.actual {
        Some(c) => { assert(c == 'y', "actual should be 'y'") }
        None => { assert(false, "actual should be Some") }
    }
    return
}

let test_error_at_with_none_actual: fn() -> void = fn() -> void {
    let pos: Position = position_new(0, 1, 1)
    let err: ParseError = error_at(pos, EndOfInput, None)
    match err.actual {
        Some(_) => { assert(false, "actual should be None") }
        None => { return }
    }
}

let test_merge_errors_takes_furthest: fn() -> void = fn() -> void {
    let e1: ParseError = error_at(position_new(5, 1, 6), Literal("a"), None)
    let e2: ParseError = error_at(position_new(10, 2, 3), Literal("b"), None)
    let merged: ParseError = merge_errors(e1, e2)
    assert(merged.position.offset == 10, "should take furthest error")
    return
}

let test_merge_errors_takes_first_if_furthest: fn() -> void = fn() -> void {
    let e1: ParseError = error_at(position_new(10, 2, 3), Literal("a"), None)
    let e2: ParseError = error_at(position_new(5, 1, 6), Literal("b"), None)
    let merged: ParseError = merge_errors(e1, e2)
    assert(merged.position.offset == 10, "should take furthest error")
    return
}

let test_merge_errors_same_position_merges: fn() -> void = fn() -> void {
    let e1: ParseError = error_at(position_new(5, 1, 6), Literal("a"), None)
    let e2: ParseError = error_at(position_new(5, 1, 6), Literal("b"), None)
    let merged: ParseError = merge_errors(e1, e2)
    assert(merged.position.offset == 5, "position should be same")
    assert(length[Expected](merged.expected) == 2, "should merge expected lists")
    return
}

// =============================================================================
// ParseResult Tests
// =============================================================================

let test_parse_result_is_success: fn() -> void = fn() -> void {
    let result: ParseResult[i32] = Success { value: 42, remaining: input_new("") }
    assert(is_success[i32](result), "should be success")
    assert(not is_failure[i32](result), "should not be failure")
    return
}

let test_parse_result_is_failure: fn() -> void = fn() -> void {
    let err: ParseError = error_at(position_new(0, 1, 1), Custom("error"), None)
    let result: ParseResult[i32] = Failure { error: err }
    assert(is_failure[i32](result), "should be failure")
    assert(not is_success[i32](result), "should not be success")
    return
}

// =============================================================================
// List Utility Tests
// =============================================================================

let test_reverse_empty_list: fn() -> void = fn() -> void {
    let empty: List[i32] = Nil
    let result: List[i32] = reverse[i32](empty)
    match result {
        Nil => { return }
        Cons(_, _) => { assert(false, "reversed empty list should be empty") }
    }
}

let test_reverse_list: fn() -> void = fn() -> void {
    let list: List[i32] = Cons(1, Cons(2, Cons(3, Nil)))
    let result: List[i32] = reverse[i32](list)
    match result {
        Cons(a, Cons(b, Cons(c, Nil))) => {
            assert(a == 3, "first should be 3")
            assert(b == 2, "second should be 2")
            assert(c == 1, "third should be 1")
        }
        _ => { assert(false, "unexpected list structure") }
    }
    return
}

let test_concat_empty_lists: fn() -> void = fn() -> void {
    let a: List[i32] = Nil
    let b: List[i32] = Nil
    let result: List[i32] = concat[i32](a, b)
    match result {
        Nil => { return }
        _ => { assert(false, "concat of empty lists should be empty") }
    }
}

let test_concat_lists: fn() -> void = fn() -> void {
    let a: List[i32] = Cons(1, Cons(2, Nil))
    let b: List[i32] = Cons(3, Cons(4, Nil))
    let result: List[i32] = concat[i32](a, b)
    assert(length[i32](result) == 4, "length should be 4")
    match result {
        Cons(x1, Cons(x2, Cons(x3, Cons(x4, Nil)))) => {
            assert(x1 == 1, "first should be 1")
            assert(x2 == 2, "second should be 2")
            assert(x3 == 3, "third should be 3")
            assert(x4 == 4, "fourth should be 4")
        }
        _ => { assert(false, "unexpected list structure") }
    }
    return
}

let test_length_empty: fn() -> void = fn() -> void {
    let empty: List[i32] = Nil
    assert(length[i32](empty) == 0, "length of empty list should be 0")
    return
}

let test_length_non_empty: fn() -> void = fn() -> void {
    let list: List[i32] = Cons(1, Cons(2, Cons(3, Nil)))
    assert(length[i32](list) == 3, "length should be 3")
    return
}

let test_list_map: fn() -> void = fn() -> void {
    let list: List[i32] = Cons(1, Cons(2, Cons(3, Nil)))
    let doubled: List[i32] = list_map[i32, i32](list, fn(x: i32) -> i32 { return x * 2 })
    match doubled {
        Cons(a, Cons(b, Cons(c, Nil))) => {
            assert(a == 2, "first should be 2")
            assert(b == 4, "second should be 4")
            assert(c == 6, "third should be 6")
        }
        _ => { assert(false, "unexpected list structure") }
    }
    return
}

let test_fold_sum: fn() -> void = fn() -> void {
    let list: List[i32] = Cons(1, Cons(2, Cons(3, Cons(4, Nil))))
    let sum: i32 = fold[i32, i32](list, 0, fn(acc: i32, x: i32) -> i32 { return acc + x })
    assert(sum == 10, "sum should be 10")
    return
}

let test_fold_empty: fn() -> void = fn() -> void {
    let empty: List[i32] = Nil
    let result: i32 = fold[i32, i32](empty, 42, fn(acc: i32, x: i32) -> i32 { return acc + x })
    assert(result == 42, "fold of empty list should return initial value")
    return
}

// =============================================================================
// String Utility Tests
// =============================================================================

let test_substring_from_start: fn() -> void = fn() -> void {
    let s: string = "hello"
    let result: string = substring(s, 0)
    assert(result == "hello", "substring from 0 should be whole string")
    return
}

let test_substring_from_middle: fn() -> void = fn() -> void {
    let s: string = "hello"
    let result: string = substring(s, 2)
    assert(result == "llo", "substring from 2 should be 'llo'")
    return
}

let test_substring_past_end: fn() -> void = fn() -> void {
    let s: string = "hello"
    let result: string = substring(s, 10)
    assert(result == "", "substring past end should be empty")
    return
}

let test_string_head_non_empty: fn() -> void = fn() -> void {
    let s: string = "hello"
    match string_head(s) {
        Some(c) => { assert(c == 'h', "head should be 'h'") }
        None => { assert(false, "head should be Some") }
    }
    return
}

let test_string_head_empty: fn() -> void = fn() -> void {
    let s: string = ""
    match string_head(s) {
        Some(_) => { assert(false, "head of empty should be None") }
        None => { return }
    }
}

let test_string_is_empty_true: fn() -> void = fn() -> void {
    assert(string_is_empty(""), "empty string should be empty")
    return
}

let test_string_is_empty_false: fn() -> void = fn() -> void {
    assert(not string_is_empty("x"), "non-empty string should not be empty")
    return
}

let test_starts_with_true: fn() -> void = fn() -> void {
    assert(starts_with("hello", "hel"), "'hello' should start with 'hel'")
    return
}

let test_starts_with_false: fn() -> void = fn() -> void {
    assert(not starts_with("hello", "world"), "'hello' should not start with 'world'")
    return
}

let test_starts_with_empty_prefix: fn() -> void = fn() -> void {
    assert(starts_with("hello", ""), "any string starts with empty prefix")
    return
}

let test_string_contains_char_true: fn() -> void = fn() -> void {
    assert(string_contains_char("hello", 'l'), "'hello' should contain 'l'")
    return
}

let test_string_contains_char_false: fn() -> void = fn() -> void {
    assert(not string_contains_char("hello", 'z'), "'hello' should not contain 'z'")
    return
}

let test_char_to_string: fn() -> void = fn() -> void {
    let s: string = char_to_string('a')
    assert(s == "a", "char_to_string('a') should be \"a\"")
    return
}

let test_chars_to_string: fn() -> void = fn() -> void {
    let chars: List[char] = Cons('a', Cons('b', Cons('c', Nil)))
    let s: string = chars_to_string(chars)
    assert(s == "abc", "chars_to_string should produce 'abc'")
    return
}

let test_chars_to_string_empty: fn() -> void = fn() -> void {
    let chars: List[char] = Nil
    let s: string = chars_to_string(chars)
    assert(s == "", "chars_to_string of empty should be empty")
    return
}

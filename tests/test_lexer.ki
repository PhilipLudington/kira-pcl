}

let test_identifier_leading_number_fails: fn() -> void = fn() -> void {
    let parser: Parser[string] = identifier()
    let result: ParseResult[string] = run[string](parser, "123foo")
    assert(is_failure[string](result), "identifier cannot start with digit")
    return
}

let test_identifier_single_letter: fn() -> void = fn() -> void {
    let parser: Parser[string] = identifier()

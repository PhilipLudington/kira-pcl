}

let test_signed_integer_positive_explicit: fn() -> void = fn() -> void {
    let parser: Parser[i64] = signed_integer()
    let result: ParseResult[i64] = run[i64](parser, "+42 ")
    match result {
        Success { value: n, remaining: _ } => {

/// Tests for the lexer module
///
/// Tests cover:
/// - Whitespace handling
/// - Token parsers (keyword, symbol, identifier, integer, string_literal)
/// - Additional lexer utilities

import src.types
import src.primitives
import src.combinators
import src.lexer

// =============================================================================
// Whitespace Tests
// =============================================================================

let test_skip_ws_empty: fn() -> void = fn() -> void {
    let parser: Parser[void] = skip_ws()
    let result: ParseResult[void] = run[void](parser, "abc")
    match result {
        Success { value: _, remaining: rest } => {
            assert(rest.pos.offset == 0, "should not consume non-whitespace")
        }
        Failure { error: _ } => {
            assert(false, "skip_ws should never fail")
        }
    }
    return
}

let test_skip_ws_spaces: fn() -> void = fn() -> void {
    let parser: Parser[void] = skip_ws()
    let result: ParseResult[void] = run[void](parser, "   abc")
    match result {
        Success { value: _, remaining: rest } => {
            assert(rest.pos.offset == 3, "should skip 3 spaces")
        }
        Failure { error: _ } => {
            assert(false, "skip_ws should never fail")
        }
    }
    return
}

let test_skip_ws_mixed_whitespace: fn() -> void = fn() -> void {
    let parser: Parser[void] = skip_ws()
    let result: ParseResult[void] = run[void](parser, " \t\n abc")
    match result {
        Success { value: _, remaining: rest } => {
            assert(rest.pos.offset == 4, "should skip mixed whitespace")
        }
        Failure { error: _ } => {
            assert(false, "skip_ws should never fail")
        }
    }
    return
}

let test_lexeme_strips_trailing_ws: fn() -> void = fn() -> void {
    let parser: Parser[char] = lexeme[char](char_p('x'))
    let result: ParseResult[char] = run[char](parser, "x   abc")
    match result {
        Success { value: c, remaining: rest } => {
            assert(c == 'x', "should parse 'x'")
            assert(rest.pos.offset == 4, "should consume 'x' and trailing spaces")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

// =============================================================================
// Keyword Tests
// =============================================================================

let test_keyword_matches_word: fn() -> void = fn() -> void {
    let parser: Parser[string] = keyword("if")
    let result: ParseResult[string] = run[string](parser, "if (x)")
    match result {
        Success { value: s, remaining: _ } => {
            assert(s == "if", "should parse 'if'")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_keyword_not_prefix: fn() -> void = fn() -> void {
    let parser: Parser[string] = keyword("if")
    let result: ParseResult[string] = run[string](parser, "iffy")
    assert(is_failure[string](result), "should not match prefix of identifier")
    return
}

let test_keyword_with_trailing_ws: fn() -> void = fn() -> void {
    let parser: Parser[string] = keyword("while")
    let result: ParseResult[string] = run[string](parser, "while   (")
    match result {
        Success { value: s, remaining: rest } => {
            assert(s == "while", "should parse 'while'")
            assert(rest.pos.offset == 8, "should consume keyword and trailing ws")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

// =============================================================================
// Symbol Tests
// =============================================================================

let test_symbol_matches: fn() -> void = fn() -> void {
    let parser: Parser[string] = symbol("+=")
    let result: ParseResult[string] = run[string](parser, "+=  x")
    match result {
        Success { value: s, remaining: rest } => {
            assert(s == "+=", "should parse '+='")
            assert(rest.pos.offset == 4, "should consume symbol and ws")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_symbol_no_match: fn() -> void = fn() -> void {
    let parser: Parser[string] = symbol("++")
    let result: ParseResult[string] = run[string](parser, "+-")
    assert(is_failure[string](result), "should fail on different symbol")
    return
}


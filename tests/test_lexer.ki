let test_parens: fn() -> void = fn() -> void {
    let parser: Parser[i64] = parens[i64](integer())
    let result: ParseResult[i64] = run[i64](parser, "( 42 ) ")
    match result {
        Success { value: n, remaining: _ } => {
            assert(n == 42, "should parse parenthesized 42")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_brackets: fn() -> void = fn() -> void {
    let parser: Parser[i64] = brackets[i64](integer())
    let result: ParseResult[i64] = run[i64](parser, "[ 42 ] ")
    match result {
        Success { value: n, remaining: _ } => {
            assert(n == 42, "should parse bracketed 42")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_braces: fn() -> void = fn() -> void {
    let parser: Parser[i64] = braces[i64](integer())
    let result: ParseResult[i64] = run[i64](parser, "{ 42 } ")
    match result {
        Success { value: n, remaining: _ } => {
            assert(n == 42, "should parse braced 42")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_comma_sep: fn() -> void = fn() -> void {
    let parser: Parser[List[i64]] = comma_sep[i64](integer())
    let result: ParseResult[List[i64]] = run[List[i64]](parser, "1, 2, 3 ")
    match result {
        Success { value: nums, remaining: _ } => {
            assert(length[i64](nums) == 3, "should parse 3 numbers")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_comma_sep_empty: fn() -> void = fn() -> void {
    let parser: Parser[List[i64]] = comma_sep[i64](integer())
    let result: ParseResult[List[i64]] = run[List[i64]](parser, "abc")
    match result {
        Success { value: nums, remaining: _ } => {
            assert(length[i64](nums) == 0, "should return empty list")
        }
        Failure { error: _ } => {
            assert(false, "comma_sep should never fail")
        }
    }
    return
}

let test_line_comment: fn() -> void = fn() -> void {
    let parser: Parser[void] = line_comment("//")
    let result: ParseResult[void] = run[void](parser, "// this is a comment\nnext line")
    match result {
        Success { value: _, remaining: rest } => {
            // Should consume up to but not including the newline
            assert(rest.pos.offset == 20, "should consume comment")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

// =============================================================================
// Integration Tests
// =============================================================================

let test_parse_assignment: fn() -> void = fn() -> void {
    // Parse: identifier = integer ;
    let parser: Parser[(string, i64)] = map3[string, string, i64, (string, i64)](
        identifier(),
        symbol("="),
        seq_left[i64, string](integer(), symbol(";")),
        fn(name: string, _: string, value: i64) -> (string, i64) {
            return (name, value)
        }
    )
    let result: ParseResult[(string, i64)] = run[(string, i64)](parser, "x = 42 ;")
    match result {
        Success { value: pair, remaining: _ } => {
            let (name, value): (string, i64) = pair
            assert(name == "x", "name should be 'x'")
            assert(value == 42, "value should be 42")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_parse_function_call: fn() -> void = fn() -> void {
    // Parse: identifier ( args )
    let args: Parser[List[i64]] = parens[List[i64]](comma_sep[i64](integer()))
    let parser: Parser[(string, List[i64])] = seq_pair[string, List[i64]](identifier(), args)
    let result: ParseResult[(string, List[i64])] = run[(string, List[i64])](parser, "foo ( 1, 2, 3 )")
    match result {
        Success { value: pair, remaining: _ } => {
            let (name, nums): (string, List[i64]) = pair
            assert(name == "foo", "name should be 'foo'")
            assert(length[i64](nums) == 3, "should have 3 arguments")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

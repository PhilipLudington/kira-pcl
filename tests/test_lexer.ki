let test_integer_positive: fn() -> void = fn() -> void {
    let parser: Parser[i64] = integer()
    let result: ParseResult[i64] = run[i64](parser, "42 ")
    match result {
        Success { value: n, remaining: _ } => {
            assert(n == 42, "should parse 42")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_integer_multidigit: fn() -> void = fn() -> void {
    let parser: Parser[i64] = integer()
    let result: ParseResult[i64] = run[i64](parser, "123456 ")
    match result {
        Success { value: n, remaining: _ } => {
            assert(n == 123456, "should parse 123456")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_integer_fails_on_letter: fn() -> void = fn() -> void {
    let parser: Parser[i64] = integer()
    let result: ParseResult[i64] = run[i64](parser, "abc")
    assert(is_failure[i64](result), "should fail on non-digit")
    return
}


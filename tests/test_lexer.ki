    }
    return
}

let test_identifier_with_numbers: fn() -> void = fn() -> void {
    let parser: Parser[string] = identifier()
    let result: ParseResult[string] = run[string](parser, "foo123 bar")
    match result {
        Success { value: s, remaining: _ } => {
            assert(s == "foo123", "should parse 'foo123'")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")

let test_identifier_simple: fn() -> void = fn() -> void {
    let parser: Parser[string] = identifier()
    let result: ParseResult[string] = run[string](parser, "foo bar")
    match result {
        Success { value: s, remaining: _ } => {
            assert(s == "foo", "should parse 'foo'")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")

    return
}

// =============================================================================
// String Literal Tests
// =============================================================================

let test_string_literal_simple: fn() -> void = fn() -> void {
    let parser: Parser[string] = string_literal()
    let result: ParseResult[string] = run[string](parser, "\"hello\" ")
    match result {
        Success { value: s, remaining: _ } => {
            assert(s == "hello", "should parse 'hello'")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_string_literal_escaped_chars: fn() -> void = fn() -> void {
    let parser: Parser[string] = string_literal()
    let result: ParseResult[string] = run[string](parser, "\"hello\\nworld\" ")
    match result {
        Success { value: s, remaining: _ } => {
            assert(s == "hello\nworld", "should parse with newline escape")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_string_literal_escaped_quote: fn() -> void = fn() -> void {
    let parser: Parser[string] = string_literal()
    let result: ParseResult[string] = run[string](parser, "\"say \\\"hi\\\"\" ")
    match result {
        Success { value: s, remaining: _ } => {
            assert(s == "say \"hi\"", "should parse with escaped quotes")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_string_literal_empty: fn() -> void = fn() -> void {
    let parser: Parser[string] = string_literal()
    let result: ParseResult[string] = run[string](parser, "\"\" ")
    match result {
        Success { value: s, remaining: _ } => {
            assert(s == "", "should parse empty string")
        }
        Failure { error: _ } => {
            assert(false, "should succeed")
        }
    }
    return
}

let test_string_literal_unclosed: fn() -> void = fn() -> void {
    let parser: Parser[string] = string_literal()
    let result: ParseResult[string] = run[string](parser, "\"hello")
    assert(is_failure[string](result), "should fail on unclosed string")
    return
}


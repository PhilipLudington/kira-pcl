// Tests for the lexer module

import src.types
import src.primitives
import src.combinators
import src.lexer

// =============================================================================
// Whitespace Tests
// =============================================================================

test "skip ws empty" {
    let parser: fn(Input) -> ParseResult = skip_ws()
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(_, rest) => {
            assert(rest.pos.offset == 0, "should not consume non-whitespace")
        }
        Failure(_) => {
            assert(false, "skip_ws should never fail")
        }
    }
}

test "skip ws spaces" {
    let parser: fn(Input) -> ParseResult = skip_ws()
    let result: ParseResult = run(parser, "   abc")
    match result {
        Success(_, rest) => {
            assert(rest.pos.offset == 3, "should skip 3 spaces")
        }
        Failure(_) => {
            assert(false, "skip_ws should never fail")
        }
    }
}

test "skip ws mixed whitespace" {
    let parser: fn(Input) -> ParseResult = skip_ws()
    let result: ParseResult = run(parser, " \t\n abc")
    match result {
        Success(_, rest) => {
            assert(rest.pos.offset == 4, "should skip mixed whitespace")
        }
        Failure(_) => {
            assert(false, "skip_ws should never fail")
        }
    }
}

test "lexeme strips trailing ws" {
    let parser: fn(Input) -> ParseResult = lexeme(char_p('x'))
    let result: ParseResult = run(parser, "x   abc")
    match result {
        Success(v, rest) => {
            assert(unwrap_char(v) == 'x', "should parse 'x'")
            assert(rest.pos.offset == 4, "should consume 'x' and trailing spaces")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

// =============================================================================
// Keyword Tests
// =============================================================================

test "keyword matches word" {
    let parser: fn(Input) -> ParseResult = keyword("if")
    let result: ParseResult = run(parser, "if (x)")
    match result {
        Success(v, _) => {
            assert(unwrap_string(v) == "if", "should parse 'if'")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "keyword not prefix" {
    let parser: fn(Input) -> ParseResult = keyword("if")
    let result: ParseResult = run(parser, "iffy")
    assert(is_failure(result), "should not match prefix of identifier")
}

test "keyword with trailing ws" {
    let parser: fn(Input) -> ParseResult = keyword("while")
    let result: ParseResult = run(parser, "while   (")
    match result {
        Success(v, rest) => {
            assert(unwrap_string(v) == "while", "should parse 'while'")
            assert(rest.pos.offset == 8, "should consume keyword and trailing ws")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

// =============================================================================
// Symbol Tests
// =============================================================================

test "symbol matches" {
    let parser: fn(Input) -> ParseResult = symbol("+=")
    let result: ParseResult = run(parser, "+=  x")
    match result {
        Success(v, rest) => {
            assert(unwrap_string(v) == "+=", "should parse '+='")
            assert(rest.pos.offset == 4, "should consume symbol and ws")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "symbol no match" {
    let parser: fn(Input) -> ParseResult = symbol("++")
    let result: ParseResult = run(parser, "+-")
    assert(is_failure(result), "should fail on different symbol")
}

// =============================================================================
// Identifier Tests
// =============================================================================

test "identifier simple" {
    let parser: fn(Input) -> ParseResult = identifier()
    let result: ParseResult = run(parser, "foo bar")
    match result {
        Success(v, _) => {
            assert(unwrap_string(v) == "foo", "should parse 'foo'")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "identifier with numbers" {
    let parser: fn(Input) -> ParseResult = identifier()
    let result: ParseResult = run(parser, "foo123 bar")
    match result {
        Success(v, _) => {
            assert(unwrap_string(v) == "foo123", "should parse 'foo123'")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "identifier leading number fails" {
    let parser: fn(Input) -> ParseResult = identifier()
    let result: ParseResult = run(parser, "123foo")
    assert(is_failure(result), "identifier cannot start with digit")
}

test "identifier single letter" {
    let parser: fn(Input) -> ParseResult = identifier()
    let result: ParseResult = run(parser, "x ")
    match result {
        Success(v, _) => {
            assert(unwrap_string(v) == "x", "should parse 'x'")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

// =============================================================================
// Integer Tests
// =============================================================================

test "integer positive" {
    let parser: fn(Input) -> ParseResult = integer()
    let result: ParseResult = run(parser, "42 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 42i64, "should parse 42")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "integer multidigit" {
    let parser: fn(Input) -> ParseResult = integer()
    let result: ParseResult = run(parser, "123456 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 123456i64, "should parse 123456")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "integer fails on letter" {
    let parser: fn(Input) -> ParseResult = integer()
    let result: ParseResult = run(parser, "abc")
    assert(is_failure(result), "should fail on non-digit")
}

test "signed integer negative" {
    let parser: fn(Input) -> ParseResult = signed_integer()
    let result: ParseResult = run(parser, "-42 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == -42i64, "should parse -42")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "signed integer positive explicit" {
    let parser: fn(Input) -> ParseResult = signed_integer()
    let result: ParseResult = run(parser, "+42 ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 42i64, "should parse +42 as 42")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

// =============================================================================
// String Literal Tests
// =============================================================================

test "string literal simple" {
    let parser: fn(Input) -> ParseResult = string_literal()
    let result: ParseResult = run(parser, "\"hello\" ")
    match result {
        Success(v, _) => {
            assert(unwrap_string(v) == "hello", "should parse 'hello'")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "string literal escaped chars" {
    let parser: fn(Input) -> ParseResult = string_literal()
    let result: ParseResult = run(parser, "\"hello\\nworld\" ")
    match result {
        Success(v, _) => {
            assert(unwrap_string(v) == "hello\nworld", "should parse with newline escape")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "string literal escaped quote" {
    let parser: fn(Input) -> ParseResult = string_literal()
    let result: ParseResult = run(parser, "\"say \\\"hi\\\"\" ")
    match result {
        Success(v, _) => {
            assert(unwrap_string(v) == "say \"hi\"", "should parse with escaped quotes")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "string literal empty" {
    let parser: fn(Input) -> ParseResult = string_literal()
    let result: ParseResult = run(parser, "\"\" ")
    match result {
        Success(v, _) => {
            assert(unwrap_string(v) == "", "should parse empty string")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "string literal unclosed" {
    let parser: fn(Input) -> ParseResult = string_literal()
    let result: ParseResult = run(parser, "\"hello")
    assert(is_failure(result), "should fail on unclosed string")
}

// =============================================================================
// Utility Tests
// =============================================================================

test "parens" {
    let parser: fn(Input) -> ParseResult = parens(integer())
    let result: ParseResult = run(parser, "( 42 ) ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 42i64, "should parse parenthesized 42")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "brackets" {
    let parser: fn(Input) -> ParseResult = brackets(integer())
    let result: ParseResult = run(parser, "[ 42 ] ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 42i64, "should parse bracketed 42")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "braces" {
    let parser: fn(Input) -> ParseResult = braces(integer())
    let result: ParseResult = run(parser, "{ 42 } ")
    match result {
        Success(v, _) => {
            assert(unwrap_int(v) == 42i64, "should parse braced 42")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "comma sep" {
    let parser: fn(Input) -> ParseResult = comma_sep(integer())
    let result: ParseResult = run(parser, "1, 2, 3 ")
    match result {
        Success(v, _) => {
            assert(std.list.length(unwrap_list(v)) == 3, "should parse 3 numbers")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "comma sep empty" {
    let parser: fn(Input) -> ParseResult = comma_sep(integer())
    let result: ParseResult = run(parser, "abc")
    match result {
        Success(v, _) => {
            assert(std.list.length(unwrap_list(v)) == 0, "should return empty list")
        }
        Failure(_) => {
            assert(false, "comma_sep should never fail")
        }
    }
}

test "line comment" {
    let parser: fn(Input) -> ParseResult = line_comment("//")
    let result: ParseResult = run(parser, "// this is a comment\nnext line")
    match result {
        Success(_, rest) => {
            assert(rest.pos.offset == 20, "should consume comment")
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

// =============================================================================
// Integration Tests
// =============================================================================

test "parse assignment" {
    // Parse: identifier = integer ;
    let parser: fn(Input) -> ParseResult = map3(
        identifier(),
        symbol("="),
        seq_left(integer(), symbol(";")),
        fn(name: Value, _eq: Value, val: Value) -> Value {
            return VPair(name, val)
        }
    )
    let result: ParseResult = run(parser, "x = 42 ;")
    match result {
        Success(v, _) => {
            match v {
                VPair(name, val) => {
                    assert(unwrap_string(name) == "x", "name should be 'x'")
                    assert(unwrap_int(val) == 42i64, "value should be 42")
                }
                _ => { assert(false, "should be VPair") }
            }
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}

test "parse function call" {
    // Parse: identifier ( args )
    let args: fn(Input) -> ParseResult = parens(comma_sep(integer()))
    let parser: fn(Input) -> ParseResult = seq_pair(identifier(), args)
    let result: ParseResult = run(parser, "foo ( 1, 2, 3 )")
    match result {
        Success(v, _) => {
            match v {
                VPair(name, arg_list) => {
                    assert(unwrap_string(name) == "foo", "name should be 'foo'")
                    assert(std.list.length(unwrap_list(arg_list)) == 3, "should have 3 arguments")
                }
                _ => { assert(false, "should be VPair") }
            }
        }
        Failure(_) => {
            assert(false, "should succeed")
        }
    }
}
